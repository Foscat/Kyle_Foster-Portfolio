{
  "source": {
    "include": [
      "src/types",
      "src/assets/hooks",
      "src/assets/utils.js",
      "src/components",
      "src/pages",
      "scripts",
      "playwright"
    ],
    "includePattern": ".+\\.(js|jsx|cjs|mjs)$"
  },
  "opts": {
    "destination": "docs",
    "recurse": true
  },
  "templates": {
    "cleverLinks": true,
    "monospaceLinks": true
  }
}
