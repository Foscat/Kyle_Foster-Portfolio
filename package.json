{
  "name": "react-portfolio",
  "private": true,
  "version": "1.1.1",
  "type": "module",
  "engines": {
    "node": ">=18 <23",
    "npm": ">=10 <11"
  },
  "scripts": {
    "build": "vite build",
    "ci:gate": "npm-run-all --sequential lint:cleanup test diagrams:check diagrams:test docs:build",
    "codemod:keys": "jscodeshift -t scripts/codemods/add-react-keys.js src",
    "codemod:map-index": "jscodeshift -t scripts/codemods/fix-unused-map-index.js src",
    "codemod:fix-jsdoc": "jscodeshift -t scripts/codemods/fix-jsdoc-import-types.js src",
    "dev": "vite",
    "diagrams:format": "node scripts/format-diagrams.js",
    "diagrams:lint": "node scripts/lint-diagrams.js && node scripts/diagrams/lint-custom-diagrams.mjs",
    "diagrams:check": "npm-run-all --sequential diagrams:format diagrams:lint",
    "diagrams:assets": "node scripts/build-diagram-assets.js",
    "diagrams:test": "playwright test",
    "diagrams:run-all": "npm-run-all --sequential diagrams:check diagrams:assets diagrams:test",
    "docs:clean": "rimraf docs",
    "docs:components": "jsdoc2md \"src/components/**/*.jsx\" > docs/components.md",
    "docs:navigation": "jsdoc2md \"src/components/navigation/**/*.{js,jsx}\" > docs/navigation.md",
    "docs:types": "jsdoc2md \"src/types/**/*.js\" > docs/types.md",
    "docs:test-helpers": "jsdoc2md \"src/tests/**/*.{js,jsx}\" > docs/tests.md",
    "docs:scripts": "jsdoc2md \"scripts/**/*.{js,cjs,mjs}\" > docs/scripts.md",
    "docs:playwright": "jsdoc2md \"playwright/**/*.{js,ts}\" > docs/playwright.md",
    "docs:api": "jsdoc2md --configure jsdoc.config.json > docs/api.md",
    "docs:jsdoc:audit": "node scripts/check-jsdoc2md-compat.mjs --write",
    "docs:jsdoc:audit:strict": "node scripts/check-jsdoc2md-compat.mjs --write --strict",
    "docs:verify": "npm-run-all --sequential lint docs:build",
    "docs:build": "npm-run-all --sequential docs:clean diagrams:lint diagrams:assets docs:mkdir docs:components docs:navigation docs:types docs:test-helpers docs:scripts docs:playwright docs:api docs:jsdoc:audit lint:report",
    "docs:diff": "npm-run-all --sequential docs:build git diff --exit-code docs",
    "docs:mkdir": "mkdirp docs",
    "lint": "eslint src --max-warnings=0",
    "lint:all": "npm-run-all --sequential lint lint:css richtext:lint diagrams:lint lint:scripts lint:playwright",
    "lint:scripts": "eslint \"scripts/*.{ts,js,cjs,mjs}\" --max-warnings=0",
    "lint:playwright": "eslint \"playwright/**/*.{js,ts}\" --max-warnings=0",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:fix": "eslint . --fix",
    "lint:fix-safe": "eslint src --fix",
    "lint:cleanup": "npm-run-all --sequential codemod:keys codemod:map-index codemod:fix-jsdoc format lint:fix-safe lint",
    "lint:report": "eslint src --format html --output-file docs/lint-report.html",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "format": "npm run prettier:fix",
    "prepare": "husky",
    "preview": "vite preview",
    "richtext:lint": "node scripts/richtext-lint.cjs",
    "richtext:fix": "node scripts/richtext-lint.cjs --fix",
    "richtext:codemod": "jscodeshift -t scripts/codemods/fix-richtext.cjs src",
    "start": "cross-env PORT=3000 vite",
    "test": "vitest run",
    "test-diagrams": "playwright test",
    "test:mobile-clickable-img": "playwright test playwright/components/clickable-img.mobile.spec.ts",
    "test:interactive-surface": "npx playwright test --config=src/click-animate/playwright.config.mjs",
    "lint:interactive-surface": "npx stylelint --config src/click-animate/.stylelintrc.cjs \"src/click-animate/interactive-surface.css\"",
    "pack:interactive-surface": "npm pack ./src/click-animate --dry-run --cache ./.npm-cache",
    "quality:check": "npm-run-all --sequential lint richtext:lint diagrams:lint test docs:build",
    "quality:fix": "npm-run-all --sequential codemod:keys codemod:map-index codemod:fix-jsdoc format lint:fix-safe"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "7.1.0",
    "@fortawesome/free-brands-svg-icons": "7.1.0",
    "@fortawesome/free-regular-svg-icons": "7.1.0",
    "@fortawesome/free-solid-svg-icons": "7.1.0",
    "@fortawesome/react-fontawesome": "3.1.1",
    "@rsuite/icons": "1.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "html-to-image": "1.11.13",
    "mermaid": "^11.12.3",
    "prismjs": "~1.30.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-helmet-async": "2.0.5",
    "react-markdown": "~10.1.0",
    "react-router": "6.30.3",
    "react-router-dom": "6.30.3",
    "rehype-raw": "~7.0.0",
    "remark-gfm": "~4.0.1",
    "rsuite": "5.83.3",
    "stylelint-config-recess-order": "~7.6.1",
    "svg-pan-zoom": "3.6.2"
  },
  "devDependencies": {
    "@babel/generator": "~7.29.1",
    "@babel/parser": "~7.29.0",
    "@babel/traverse": "~7.29.0",
    "@babel/types": "~7.29.0",
    "@eslint/js": "9.39.2",
    "@mermaid-js/mermaid-cli": "~11.12.0",
    "@mermaid-js/parser": "1.0.0",
    "@playwright/test": "1.57.0",
    "@swc/core": "1.9.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.1",
    "@vitest/coverage-v8": "4.0.16",
    "cross-env": "7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-html": "2.7.3",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsdoc": "61.5.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "eslint-plugin-testing-library": "^7.15.4",
    "eslint-plugin-unused-imports": "4.3.0",
    "eslint-plugin-vitest": "0.5.4",
    "glob": "~13.0.6",
    "globals": "16.5.0",
    "husky": "9.1.7",
    "identity-obj-proxy": "3.0.0",
    "jscodeshift": "17.3.0",
    "jsdoc": "4.0.5",
    "jsdoc-to-markdown": "9.1.3",
    "jsdom": "27.4.0",
    "lint-staged": "16.2.7",
    "mkdirp": "^3.0.1",
    "npm-run-all": "^4.1.5",
    "prettier": "3.7.4",
    "rimraf": "6.1.2",
    "stylelint": "^17.1.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^7.0.1",
    "vite": "5.4.21",
    "vitest": "4.0.16"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "eslint --fix"
    ]
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "lodash-es": "^4.17.23",
    "minimatch": "^10.2.1",
    "yauzl": "3.2.1"
  }
}
